-- LocalScript (StarterGui or StarterPlayerScripts)

local player = game.Players.LocalPlayer

-- Create ScreenGui
local gui = Instance.new("ScreenGui")
gui.Name = "SansHub"
gui.Parent = player:WaitForChild("PlayerGui")

-- Main Frame (BIGGER)
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 500, 0, 300)
frame.Position = UDim2.new(0.5, -250, 0.5, -150)
frame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
frame.Active = true
frame.Draggable = true
frame.Parent = gui

-- Title
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 50)
title.Text = "SANS HUB"
title.TextScaled = true
title.BackgroundTransparency = 1
title.TextColor3 = Color3.fromRGB(255,255,255)
title.Parent = frame

-- Function to create buttons
local function createButton(text, yPos)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 220, 0, 50)
    btn.Position = UDim2.new(0, 20, 0, yPos)
    btn.Text = text
    btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.Parent = frame
    return btn
end

-- Example Buttons
local carpetToggle = createButton("Flying Carpet: OFF", 70)
local speedToggle = createButton("Speed Boost: OFF", 140)
local jumpToggle = createButton("High Jump: OFF", 210)

-- States
local carpetOn = false
local speedOn = false
local jumpOn = false

local playerChar = player.Character or player.CharacterAdded:Wait()

-- Flying Carpet Toggle (legit equip)
carpetToggle.MouseButton1Click:Connect(function()
    carpetOn = not carpetOn
    carpetToggle.Text = "Flying Carpet: " .. (carpetOn and "ON" or "OFF")

    local tool = player.Backpack:FindFirstChild("Flying Carpet") or playerChar:FindFirstChild("Flying Carpet")
    if tool then
        tool.Parent = carpetOn and playerChar or player.Backpack
    end
end)

-- Speed Boost (legit stat change)
speedToggle.MouseButton1Click:Connect(function()
    speedOn = not speedOn
    speedToggle.Text = "Speed Boost: " .. (speedOn and "ON" or "OFF")

    local humanoid = playerChar:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid.WalkSpeed = speedOn and 32 or 16
    end
end)

-- High Jump
jumpToggle.MouseButton1Click:Connect(function()
    jumpOn = not jumpOn
    jumpToggle.Text = "High Jump: " .. (jumpOn and "ON" or "OFF")

    local humanoid = playerChar:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid.JumpPower = jumpOn and 100 or 50
    end
end)
