-- Button Creator
local function createButton(text, y)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0, 240, 0, 50)
	btn.Position = UDim2.new(0, 20, 0, y)
	btn.BackgroundColor3 = Color3.fromRGB(35,35,35)
	btn.TextColor3 = Color3.fromRGB(255,255,255)
	btn.Font = Enum.Font.Gotham
	btn.TextScaled = true
	btn.Text = text
	btn.Parent = frame

	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0,10)
	c.Parent = btn

	return btn
end

-- Buttons
local carpetBtn = createButton("Flying Carpet: OFF", 100)
local speedBtn = createButton("Speed Boost: OFF", 170)
local jumpBtn = createButton("High Jump: OFF", 240)

-- States
local carpet = false
local speed = false
local jump = false

local char = player.Character or player.CharacterAdded:Wait()

-- Carpet
carpetBtn.MouseButton1Click:Connect(function()
	carpet = not carpet
	carpetBtn.Text = "Flying Carpet: " .. (carpet and "ON" or "OFF")

	local tool = player.Backpack:FindFirstChild("Flying Carpet") or char:FindFirstChild("Flying Carpet")
	if tool then
		tool.Parent = carpet and char or player.Backpack
	end
end)

-- Speed
speedBtn.MouseButton1Click:Connect(function()
	speed = not speed
	speedBtn.Text = "Speed Boost: " .. (speed and "ON" or "OFF")

	local hum = char:FindFirstChildOfClass("Humanoid")
	if hum then
		hum.WalkSpeed = speed and 32 or 16
	end
end)

-- Jump
jumpBtn.MouseButton1Click:Connect(function()
	jump = not jump
	jumpBtn.Text = "High Jump: " .. (jump and "ON" or "OFF")

	local hum = char:FindFirstChildOfClass("Humanoid")
	if hum then
		hum.JumpPower = jump and 100 or 50
	end
end)
